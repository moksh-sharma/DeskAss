# ===== HelpDesk Assistant - Backend configuration =====

# --- Application ---
APP_NAME=HelpDesk Assistant
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8003

# CORS (comma separated). Electron dev server + packaged app.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,app://-

# --- Ollama (LLM) ---
OLLAMA_BASE_URL=http://172.16.200.26:11434
DEFAULT_MODEL=qwen2.5:latest
# Faster model for full-scan AI summary (keeps chat/diagnosis on DEFAULT_MODEL).
SUMMARY_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_TEMPERATURE=0.2

# --- AI generation (grounded over live scan data) ---
# Investigation/diagnosis: LLM rewrites probe facts (slow on remote Ollama). false = fast deterministic answers.
INVESTIGATION_USE_LLM=false
# Full machine scan: LLM summary is on-demand via "Generate AI Summary" button.
MACHINE_SCAN_USE_LLM=false

# --- Chat troubleshooter speed tuning ---
# "domain" = scan only the scanners the issue needs (fast); "full" = whole machine.
INVESTIGATION_SCAN_MODE=domain
# Faster model when INVESTIGATION_USE_LLM=true (blank = DEFAULT_MODEL).
INVESTIGATION_MODEL=llama3.2:3b
# Cap diagnosis LLM output (tokens). Lower = faster.
INVESTIGATION_MAX_TOKENS=400
# Reuse a recent scoped scan for repeated chat questions (seconds).
INVESTIGATION_SCAN_CACHE_SECONDS=45
# Deep storage budgets for CHAT (storage-domain questions only).
INVESTIGATION_STORAGE_TREE_BUDGET_SECONDS=30
INVESTIGATION_STORAGE_DUPLICATE_BUDGET_SECONDS=5

# Deep storage on Full System Scan (false = quick storage only; use /api/storage/scan for deep walk).
STORAGE_DEEP_ON_FULL_SCAN=false
STORAGE_DEEP_TREE_BUDGET_SECONDS=60
STORAGE_DEEP_DUPLICATE_BUDGET_SECONDS=15

# --- Speech-to-Text (ElevenLabs Scribe - recommended) ---
STT_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
# Batch file upload (/api/voice/transcribe)
ELEVENLABS_STT_MODEL=scribe_v2
# Live mic - Scribe v2 Realtime (do not change unless ElevenLabs adds a newer model)
ELEVENLABS_STT_REALTIME_MODEL=scribe_v2_realtime
# vad = segment on pauses (recommended); manual = commit only when recording stops
ELEVENLABS_REALTIME_COMMIT_STRATEGY=vad
# multi = auto Hindi + English; or set en / hi
ELEVENLABS_LANGUAGE=multi
ELEVENLABS_TIMEOUT_SECONDS=120

# --- Deepgram (legacy fallback if STT_PROVIDER=deepgram) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
DEEPGRAM_TIMEOUT_SECONDS=120

# --- RAG / Knowledge base ---
CHROMA_DIR=./chroma_store
EMBEDDING_MODEL=all-MiniLM-L6-v2
KB_COLLECTION=troubleshooting_kb
RAG_TOP_K=4

# --- OCR ---
# Windows uses built-in OCR (no install). Tesseract is optional fallback:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# --- Database ---
DATABASE_URL=sqlite:///./data/cache_assistant.sqlite3

# --- Storage ---
UPLOAD_DIR=./uploads

# --- Support tickets (raise ticket from chat) ---
TICKET_EMAIL_TO=techbank@cachedigitech.com
# auto | smtp | graph - auto uses Graph when Azure credentials below are set.
TICKET_EMAIL_TRANSPORT=auto
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=moksh@cachedigitech.com
SMTP_PASSWORD=
SMTP_FROM=moksh@cachedigitech.com
SMTP_USE_TLS=true
# Microsoft Graph (use when M365 SMTP AUTH is disabled on the tenant)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_SEND_AS_USER=moksh@cachedigitech.com

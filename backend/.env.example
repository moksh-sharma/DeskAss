# ===== Cache AI Assistant - Backend configuration =====

# --- Application ---
APP_NAME=Cache AI Assistant
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma separated). Electron dev server + packaged app.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,app://-

# --- Ollama (LLM) ---
OLLAMA_BASE_URL=http://172.16.200.26:11434
DEFAULT_MODEL=qwen2.5:latest
OLLAMA_TIMEOUT_SECONDS=360
OLLAMA_TEMPERATURE=0.2

# --- Vosk (Speech-to-Text) ---
VOSK_API_URL=http://172.16.200.26:8001
VOSK_TIMEOUT_SECONDS=120

# --- RAG / Knowledge base ---
CHROMA_DIR=./chroma_store
EMBEDDING_MODEL=all-MiniLM-L6-v2
KB_COLLECTION=troubleshooting_kb
RAG_TOP_K=4

# --- OCR ---
# Path to the Tesseract executable (Windows default shown). Leave blank to use PATH.
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Database ---
DATABASE_URL=sqlite:///./data/cache_assistant.sqlite3

# --- Storage ---
UPLOAD_DIR=./uploads

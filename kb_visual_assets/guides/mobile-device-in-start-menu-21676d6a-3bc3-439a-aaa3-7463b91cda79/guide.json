    {
      "title": "How do I connect my Android or iPhone® to my Windows PC from the Start menu?",
      "steps": [
        {
          "step": 6,
          "text": "Open the Start menu.",
          "caption": null,
          "image": null
        },
        {
          "step": 7,
          "text": "Select your device type (Android or iPhone®) from the pane.",
          "caption": null,
          "image": null
        },
        {
          "step": 8,
          "text": "Follow the on-screen instructions to complete the connection.",
          "caption": null,
          "image": null
        }
      ]
    },
    {
      "title": "How do I enable or disable mobile device content from showing in the Start menu?",
      "steps": [
        {
          "step": 9,
          "text": "Open Settings on your PC.",
          "caption": null,
          "image": null
        },
        {
          "step": 10,
          "text": "Select Personalization > Start .",
          "caption": null,
          "image": null
        },
        {
          "step": 11,
          "text": "Scroll to Show mobile device in Start toggle on or off to hide or show your mobile device in Start menu.",
          "caption": null,
          "image": null
        }
      ]
    },
    {
      "title": "What features are available for connected Android users?",
